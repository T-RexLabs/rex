# Copy to .env in the same directory before bringing the
# compose stack up. Never commit a real .env to git.
#
# Required:
REX_PG_PASSWORD=replace-me-with-a-real-secret

# Required when using `--profile tls` (caddy):
# Public hostname Caddy provisions a Let's Encrypt cert for.
# REX_CENTRAL_HOST=central.example.com
