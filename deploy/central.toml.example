# rex-central non-secret defaults (central-node.DEPLOY.2).
# Mounted at /etc/rex/central.toml inside the container.
#
# Secrets (DB password, identity material) belong in env vars
# that the bundled docker-compose.yml passes through; do NOT
# put them here.

[server]
# Address the binary listens on. Inside the bundled compose,
# this is overridden by REX_CENTRAL_ADDR=0.0.0.0:8080 so caddy
# can reach it. Bare-metal deployments without a reverse proxy
# usually want 127.0.0.1:<port> + a host-level TLS terminator.
addr = "127.0.0.1:8080"

# Max wait on SIGTERM/SIGINT before forcing exit.
shutdown_timeout = "15s"

[db]
# Empty DSN means "use the in-memory store" (events lost on
# restart). The bundled compose sets REX_CENTRAL_DB_DSN via env
# from the postgres service.
dsn = ""

[auth]
# Path to the authorized-keys TOML file (sync.SEC.1). Empty
# disables signature verification — fine for dev, never in
# production. Relative paths resolve against this config file's
# directory.
keys_file = ""

[log]
# debug | info | warn | error. Defaults to info; unknown values
# fall back to info (typo-tolerant — never silently disable
# observability).
level = "info"

# json (HEALTH.3 default for production) | text (local dev).
format = "json"

[backup]
# Where the scheduled pg_dump writes (BACKUP.1). Empty disables
# the scheduler entirely; the bundled docker-compose mounts a
# named volume here so dumps survive `docker compose down`.
# `rex-central backup --output <path>` (one-shot) works whether
# or not this is set.
dir = "/var/lib/rex/backups"

# How often the scheduler fires. Default 24h per BACKUP.1.
# Anything <= 0 disables the scheduler.
cadence = "24h"

# Cap on the number of dumps kept on disk; older files are
# deleted after each successful run. 0 means "keep forever" —
# pair with an external retention policy (S3 lifecycle, etc.)
# when you want unbounded history off-host.
retention = 14

[bootstrap]
# Where to drop the one-time admin claim token (BOOT.1) on
# startup, before any admin has redeemed it. The server also
# logs the token at WARN on every startup until redemption, so
# operators who don't want a token file on disk can leave this
# empty and read it from the logs instead. The bundled compose
# mounts the rex-state volume here so the token survives a
# container restart.
token_file = "/var/lib/rex/bootstrap.token"
