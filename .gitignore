# Build artifacts
/bin/
/dist/
*.test
*.out
coverage.txt
coverage.html

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Local tooling state (per-machine, ephemeral)
# - .claude: Claude Code plugin state (e.g. installed skills like
#   the playwright-cli skill bundle).
# - .playwright, .playwright-cli, .playwright-mcp: playwright session
#   data, per-machine config, and the screenshot/console log artifacts
#   it leaves behind while driving a browser.
# - .rtk: Rust Token Killer per-machine cache (token-savings
#   analytics + command history). Nothing in here is repo state.
.claude/
.playwright/
.playwright-cli/
.playwright-mcp/
.rtk/

# Local config not checked in
/.rex/
*.local.yaml

# Local test/scratch workspaces — these get created by ad-hoc
# `rex workspace init` runs at the repo root. Anything under
# /test/ that's a real Rex workspace (its own .rex/ skeleton)
# is per-machine state, not source.
/test/

# Local env files
.env
.env.local

# Parked central node. The centralized server code lives here while it
# is being broken out into its own service; it is git-ignored on purpose
# so the open-source local node (cmd/rex + shared core) is what's tracked.
# Still part of the same Go module and present on disk, so the *-central
# Makefile targets, `make test-pg`, and `make web-dev` work locally.
# DO NOT push this directory; the git remote is mid-migration.
/rex-centralized/
