{{define "base"}}<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <title>{{block "title" .}}rex{{end}}</title>
  <link rel="stylesheet" href="/static/app.css">
  <link rel="stylesheet" href="/static/chroma.css">
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="/">rex{{if eq .Shell "central"}} <span class="brand-suffix">central</span>{{end}}</a>
      {{if eq .Shell "central"}}
        <nav class="breadcrumb" aria-label="breadcrumb">
          <a href="/" {{if eq .NavSection "home"}}aria-current="page"{{end}}>home</a>
          {{if and .OrgID .WorkspaceID}}
            <span class="nav-sep">/</span>
            <a href="/orgs/{{.OrgID}}">org</a>
            <span class="nav-sep">/</span>
            <a href="/orgs/{{.OrgID}}/workspaces">workspaces</a>
            <span class="nav-sep">/</span>
            <a href="/orgs/{{.OrgID}}/workspaces/{{.WorkspaceID}}"><code>{{.WorkspaceID}}</code></a>
          {{else if .OrgID}}
            <span class="nav-sep">/</span>
            <a href="/orgs/{{.OrgID}}"><code>{{.OrgID}}</code></a>
          {{end}}
        </nav>
        <form class="topbar-signout" method="post" action="/auth/logout">
          <button class="btn btn-small" type="submit">sign out</button>
        </form>
      {{else}}
        <nav class="nav" aria-label="primary">
          <a href="/"         {{if eq .NavSection "home"}}aria-current="page"{{end}}>overview</a>
          <a href="/specs"    {{if eq .NavSection "specs"}}aria-current="page"{{end}}>specs</a>
          <a href="/runs"     {{if eq .NavSection "runs"}}aria-current="page"{{end}}>runs</a>
          <a href="/settings" {{if eq .NavSection "settings"}}aria-current="page"{{end}}>settings</a>
        </nav>
        <form class="topbar-search" method="get" action="/search" role="search">
          <input class="topbar-search-input"
                 type="search"
                 name="q"
                 placeholder="search…"
                 aria-label="search workspace"
                 autocomplete="off">
          {{template "scope_picker" .SearchScope}}
        </form>
      {{end}}
    </div>
    {{if eq .Shell "central"}}
      {{if and .OrgID .WorkspaceID}}
        <div class="subnav-inner">
          <nav class="nav" aria-label="primary">
            <a href="/orgs/{{.OrgID}}/workspaces/{{.WorkspaceID}}"           {{if eq .NavSection "workspace"}}aria-current="page"{{end}}>overview</a>
            <a href="/orgs/{{.OrgID}}/workspaces/{{.WorkspaceID}}/specs"     {{if eq .NavSection "specs"}}aria-current="page"{{end}}>specs</a>
            <a href="/orgs/{{.OrgID}}/workspaces/{{.WorkspaceID}}/runs"      {{if eq .NavSection "runs"}}aria-current="page"{{end}}>runs</a>
            <a href="/orgs/{{.OrgID}}/workspaces/{{.WorkspaceID}}/search"    {{if eq .NavSection "search"}}aria-current="page"{{end}}>search</a>
            <a href="/orgs/{{.OrgID}}/workspaces/{{.WorkspaceID}}/settings"  {{if eq .NavSection "settings"}}aria-current="page"{{end}}>settings</a>
          </nav>
        </div>
      {{else if .OrgID}}
        <div class="subnav-inner">
          <nav class="nav" aria-label="primary">
            <a href="/orgs/{{.OrgID}}"                {{if eq .NavSection "org"}}aria-current="page"{{end}}>overview</a>
            <a href="/orgs/{{.OrgID}}/members"        {{if eq .NavSection "members"}}aria-current="page"{{end}}>members</a>
            <a href="/orgs/{{.OrgID}}/roles"          {{if eq .NavSection "roles"}}aria-current="page"{{end}}>roles</a>
            <a href="/orgs/{{.OrgID}}/audit"          {{if eq .NavSection "audit"}}aria-current="page"{{end}}>audit</a>
            <a href="/orgs/{{.OrgID}}/workspaces"     {{if eq .NavSection "workspaces"}}aria-current="page"{{end}}>workspaces</a>
            <a href="/orgs/{{.OrgID}}/idp"            {{if eq .NavSection "idp"}}aria-current="page"{{end}}>identity</a>
            <a href="/orgs/{{.OrgID}}/encryption-keys" {{if eq .NavSection "encryption-keys"}}aria-current="page"{{end}}>encryption</a>
          </nav>
        </div>
      {{end}}
    {{end}}
  </header>
  <main class="main">
    {{if .CentralOnly}}
      <aside class="banner banner-info banner-central-only" role="status">
        <strong>CENTRAL ONLY.</strong>
        This surface exists only on central nodes — the local UI
        omits it because the feature lives on the central tenant
        (web-ui.CENTRAL.2).
      </aside>
    {{end}}
    {{block "content" .}}{{end}}
  </main>
  <footer class="footer">
    <span>rex {{.Version}}</span>
    <span>{{if eq .Shell "central"}}central{{else}}local{{end}} · {{.BindAddr}}</span>
  </footer>
  <script src="/static/sort.js" defer></script>
  <script src="/static/spec-tab-memory.js" defer></script>
</body>
</html>{{end}}
