{{define "title"}}rex — run {{.Detail.Name}}{{end}}

{{define "content"}}
<header class="page-header">
  <p class="runid-heading">{{.Detail.Name}}</p>
  <div class="meta">
    <span class="pill pill-{{.Detail.Status}}"><i class="dot"></i>{{.Detail.Status}}</span>
    <span>·</span>
    <span class="pill pill-{{.Detail.Kind}}">{{.Detail.Kind}}</span>
    <span>·</span>
    <code class="muted">{{.Detail.RunID}}</code>
    <span>·</span>
    <span>{{len .Detail.Events}} event{{if ne (len .Detail.Events) 1}}s{{end}}</span>
  </div>
  <div class="meta">
    {{if .Detail.StartedAt}}
      <span>started {{.Detail.StartedAt}}</span>
    {{end}}
    {{if .Detail.EndedAt}}
      <span>·</span>
      <span>ended {{.Detail.EndedAt}}</span>
    {{end}}
    {{if .Detail.Duration}}
      <span>·</span>
      <span>duration {{.Detail.Duration}}</span>
    {{end}}
  </div>
  {{if or .Detail.SpecRefs .Detail.FromTask}}
    <div class="meta">
      {{if .Detail.FromTask}}
        <span>from task: <code>{{.Detail.FromTask}}</code></span>
      {{end}}
      {{if .Detail.SpecRefs}}
        {{if .Detail.FromTask}}<span>·</span>{{end}}
        <span>spec refs:
          {{range $i, $ref := .Detail.SpecRefs}}{{if $i}}, {{end}}<code>{{$ref}}</code>{{end}}
        </span>
      {{end}}
    </div>
  {{end}}
</header>

{{if not .Detail.Terminal}}
  <section class="section">
    <div class="callout">
      <p><strong>live tail not available on central in v1.</strong>
         This run has not yet reported a terminal status. The
         live-stream surface (SSE + permission prompts) lands with
         <code>central-live-run-watching</code>; in the meantime,
         reload the page to see new events as they sync from the
         local node.</p>
    </div>
  </section>
{{end}}

<section class="section">
  <h2>events</h2>
  {{if .Detail.Events}}
    <div class="card">
      <ol class="event-timeline">
        {{range .Detail.Events}}
          <li class="event">
            <div class="event-head">
              <code class="event-type">{{.Type}}</code>
              <span class="muted small">{{.Timestamp}}</span>
              <span class="muted small">·</span>
              <code class="muted small">{{.ID}}</code>
            </div>
            {{with $pretty := pretty .Payload}}
              <pre class="event-payload"><code>{{$pretty}}</code></pre>
            {{end}}
          </li>
        {{end}}
      </ol>
    </div>
  {{else}}
    <p class="muted small">no events for this run yet</p>
  {{end}}
</section>
{{end}}
