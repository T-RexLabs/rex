{{define "title"}}rex — {{.Spec.ID}}{{end}}

{{define "spec-ad-hoc-form"}}
  <div class="card spec-ad-hoc">
    {{if not .Harnesses}}
      <p class="muted small">No harness adapters are registered in this build. Configure one with <code>rex tools mcp add</code> or run the CLI's <code>rex spec ask</code> instead.</p>
    {{else}}
      <form method="post" action="/specs/{{.Spec.ID}}/ask" class="form spec-ad-hoc-form">
        <div class="form-grid">
          <label class="field">
            <span class="field-label">action</span>
            <select class="field-input" name="action">
              <option value="review" selected>review (read-only commentary, like <code>rex spec ask</code>)</option>
              <option value="amend">amend (draft a YAML amendment, like <code>rex spec amend</code>)</option>
              <option value="draft">draft (produce a complete spec body)</option>
            </select>
          </label>
          <label class="field">
            <span class="field-label">harness</span>
            <select class="field-input" name="harness" required>
              <option value="">select a harness</option>
              {{range .Harnesses}}
                <option value="{{.Name}}">{{.Name}}</option>
              {{end}}
            </select>
          </label>
          <label class="field full">
            <span class="field-label">prompt</span>
            <textarea class="field-input mono" name="prompt" rows="6" required autofocus placeholder="what's missing in the SCOPE component?"></textarea>
            <span class="field-hint">The harness opens with this spec's full YAML preloaded; your prompt is the instruction. Action shapes the closing instruction (review → Markdown commentary; amend → YAML body for <code>specs/_proposed/</code>; draft → full spec body).</span>
          </label>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">start run</button>
        </div>
      </form>
    {{end}}
  </div>
{{end}}

{{define "content"}}
<header class="page-header">
  <div class="header-row">
    <h1>{{.Spec.Name}}</h1>
    <div class="header-actions">
      <a class="btn" href="/specs/{{.Spec.ID}}/edit">edit</a>
    </div>
  </div>
  <div class="meta">
    <code>{{.Spec.ID}}</code>
    <span>·</span>
    <span class="pill pill-{{.Spec.State}}"><i class="dot"></i>{{.Spec.State}}</span>
    {{if .Spec.UpdatedAt}}<span>·</span><span>updated <time>{{.Spec.UpdatedAt}}</time></span>{{end}}
    {{if .Amendments}}<span>·</span><a href="/amendments?for={{.Spec.ID}}">{{len .Amendments}} amendment{{if ne (len .Amendments) 1}}s{{end}}</a>{{end}}
    <span class="back"><a href="/specs"><span aria-hidden="true">←</span> all specs</a></span>
  </div>
</header>

{{if .Amendments}}
  <aside class="amendments-panel">
    <header class="amendments-panel-head">
      <span class="amendments-panel-title">proposed amendments</span>
      <a class="amendments-panel-link" href="/amendments?for={{.Spec.ID}}">filter to this spec →</a>
    </header>
    <ul class="amendments-panel-list">
      {{range .Amendments}}
        <li>
          <span class="pill pill-{{.State}}"><i class="dot"></i>{{.State}}</span>
          <a href="/amendments/{{.Stem}}"><code>{{.Stem}}</code></a>
          {{if .AmendmentDate}}<span class="muted small"><time>{{.AmendmentDate}}</time></span>{{end}}
          {{if .SummaryFirst}}<span class="muted small">— {{.SummaryFirst}}</span>{{end}}
        </li>
      {{end}}
    </ul>
  </aside>
{{end}}

<nav class="tabs" aria-label="spec view">
  <a class="tab"
     {{if eq .ActiveTab "rendered"}}aria-selected="true"{{end}}
     href="?tab=rendered">rendered</a>
  <a class="tab"
     {{if eq .ActiveTab "ask"}}aria-selected="true"{{end}}
     href="?tab=ask">ask</a>
  <a class="tab"
     {{if eq .ActiveTab "source"}}aria-selected="true"{{end}}
     href="?tab=source">yaml source</a>
  <a class="tab"
     {{if eq .ActiveTab "tasks"}}aria-selected="true"{{end}}
     href="?tab=tasks">tasks <span class="count">{{len .Spec.Tasks}}</span></a>
  <a class="tab"
     {{if eq .ActiveTab "runs"}}aria-selected="true"{{end}}
     href="?tab=runs">runs <span class="count">{{.RunCount}}</span></a>
</nav>

<section class="section">
  {{if eq .ActiveTab "rendered"}}
    {{if .Spec.DescriptionParas}}
      <div class="prose">
        {{range .Spec.DescriptionParas}}<p>{{.}}</p>{{end}}
      </div>
    {{else}}
      <p class="muted">no description.</p>
    {{end}}

    {{if .Spec.Components}}
      <h2 class="section-h2">components</h2>
      {{range $cid := .Spec.ComponentOrder}}
        {{$c := index $.Spec.Components $cid}}
        <article class="component-block">
          <header class="component-block-head">
            <span class="component-id">{{$cid}}</span>
            <span class="component-name">{{$c.Name}}</span>
            <span class="component-count">{{len $c.Requirements}} requirement{{if ne (len $c.Requirements) 1}}s{{end}}</span>
          </header>
          {{range $rid := $c.RequirementOrder}}
            {{$r := index $c.Requirements $rid}}
            <div class="requirement" id="{{$.Spec.ID}}.{{$cid}}.{{$rid}}">
              <div class="requirement-acid">
                <a class="acid"
                   data-acid="{{$.Spec.ID}}.{{$cid}}.{{$rid}}"
                   href="#{{$.Spec.ID}}.{{$cid}}.{{$rid}}"
                   title="copy acid">{{$.Spec.ID}}.{{$cid}}.{{$rid}}</a>
              </div>
              <div class="requirement-text">{{$r.Text}}</div>
            </div>
          {{end}}
        </article>
      {{end}}
    {{end}}

    {{if .Spec.Constraints}}
      <h2 class="section-h2">constraints</h2>
      {{range $cid := .Spec.ConstraintOrder}}
        {{$c := index $.Spec.Constraints $cid}}
        <article class="component-block">
          <header class="component-block-head">
            <span class="component-id">{{$cid}}</span>
            <span class="component-name">{{$c.Description}}</span>
            <span class="component-count">{{len $c.Requirements}} rule{{if ne (len $c.Requirements) 1}}s{{end}}</span>
          </header>
          {{range $rid := $c.RequirementOrder}}
            {{$r := index $c.Requirements $rid}}
            <div class="requirement" id="{{$.Spec.ID}}.{{$cid}}.{{$rid}}">
              <div class="requirement-acid">
                <a class="acid"
                   data-acid="{{$.Spec.ID}}.{{$cid}}.{{$rid}}"
                   href="#{{$.Spec.ID}}.{{$cid}}.{{$rid}}"
                   title="copy acid">{{$.Spec.ID}}.{{$cid}}.{{$rid}}</a>
              </div>
              <div class="requirement-text">{{$r.Text}}</div>
            </div>
          {{end}}
        </article>
      {{end}}
    {{end}}

  {{else if eq .ActiveTab "source"}}
    {{if .YAMLPretty}}
      <pre class="source chroma"><code class="language-yaml">{{.YAMLPretty}}</code></pre>
    {{else}}
      <pre class="source"><code>{{.RawYAML}}</code></pre>
    {{end}}

  {{else if eq .ActiveTab "tasks"}}
    {{if .Spec.Tasks}}
      <div class="card">
        {{range .Spec.Tasks}}
          {{$runs := index $.RunsByTask .ID}}
          <div class="task">
            <div class="task-id"><code>{{.ID}}</code></div>
            <div><span class="pill pill-{{.State}}"><i class="dot"></i>{{.State}}</span></div>
            <div class="task-body">
              <div>{{.Description}}</div>
              {{if .References}}
                <div class="task-refs">
                  {{range .References}}
                    <a class="acid acid-sm" data-acid="{{.}}" href="#" title="copy acid">{{.}}</a>
                  {{end}}
                </div>
              {{end}}
              <div class="task-actions">
                {{if .HasRecipe}}
                  <form class="task-run" method="post" action="/specs/{{$.Spec.ID}}/tasks/{{.ID}}/run">
                    <button type="submit" class="btn btn-primary">run this task</button>
                    <span class="muted">via <code>{{.RecipeKind}}</code> recipe</span>
                  </form>
                {{end}}
                <a class="btn btn-ghost"
                   href="/runs/new?from_task={{$.Spec.ID}}.{{.ID}}"
                   title="Open the run-start form with this task pre-attached">start a run →</a>
              </div>
              {{if $runs}}
                {{$latest := index $runs 0}}
                <details class="task-runs">
                  <summary>
                    <span class="pill pill-{{$latest.Status}}" title="latest run: {{$latest.Status}}"><i class="dot"></i>{{len $runs}} run{{if ne (len $runs) 1}}s{{end}}</span>
                    <span class="muted">latest <a href="{{$latest.LinkBase}}/runs/{{$latest.RunID}}"><code>{{$latest.Name}}</code></a></span>
                  </summary>
                  <ul class="task-runs-list">
                    {{range $runs}}
                      <li>
                        <span class="pill pill-{{.Status}} pill-sm"><i class="dot"></i>{{.Status}}</span>
                        <a href="{{.LinkBase}}/runs/{{.RunID}}"><code>{{.Name}}</code></a>
                        <time class="muted small">{{.StartedAt}}</time>
                      </li>
                    {{end}}
                  </ul>
                </details>
              {{end}}
            </div>
          </div>
        {{end}}
      </div>
      {{if .UntaskedRuns}}
        <div class="card untasked-runs">
          <h3 class="section-h3">runs citing this spec without a task</h3>
          <ul class="task-runs-list">
            {{range .UntaskedRuns}}
              <li>
                <span class="pill pill-{{.Status}} pill-sm"><i class="dot"></i>{{.Status}}</span>
                <a href="{{.LinkBase}}/runs/{{.RunID}}"><code>{{.Name}}</code></a>
                <time class="muted small">{{.StartedAt}}</time>
              </li>
            {{end}}
          </ul>
        </div>
      {{end}}
    {{else}}
      <p class="muted">no tasks defined.</p>
    {{end}}

  {{else if eq .ActiveTab "ask"}}
    <p class="muted small">Drive a harness against this spec without writing a recipe in the YAML. The harness opens with the spec's full content preloaded; your prompt is the instruction. Output lands on <a href="/runs?spec={{.Spec.ID}}">the runs list</a> and on <a href="?tab=runs">this spec's runs tab</a>.</p>
    {{template "spec-ad-hoc-form" .}}

  {{else if eq .ActiveTab "runs"}}
    {{if .AllRuns}}
      <p class="muted small">{{len .AllRuns}} run{{if ne (len .AllRuns) 1}}s{{end}} cite this spec via <code>from_task</code> or <code>spec_refs</code>. Most recent first.</p>
      <div class="card">
        <table class="table">
          <thead>
            <tr>
              <th>name</th>
              <th>kind</th>
              <th>status</th>
              <th>from task</th>
              <th>started</th>
            </tr>
          </thead>
          <tbody>
            {{range .AllRuns}}
              <tr>
                <td><a href="{{.LinkBase}}/runs/{{.RunID}}"><code>{{.Name}}</code></a></td>
                <td><span class="pill pill-{{.Kind}}">{{.Kind}}</span></td>
                <td><span class="pill pill-{{.Status}}"><i class="dot"></i>{{.Status}}</span></td>
                <td>
                  {{if .FromTask}}
                    <code class="muted small">{{.FromTask}}</code>
                  {{else}}
                    <span class="dim">—</span>
                  {{end}}
                </td>
                <td><time class="muted small">{{.StartedAt}}</time></td>
              </tr>
            {{end}}
          </tbody>
        </table>
      </div>
      <p class="muted small">Need broader context? <a href="/runs?spec={{.Spec.ID}}">View this list on the runs page</a> for sortable columns + filters.</p>
    {{else}}
      <p class="muted">no runs cite this spec yet.</p>
      <p class="muted small">Start one from the <a href="?tab=ask">ask tab</a> (drive a harness with the spec preloaded), the <a href="?tab=tasks">tasks tab</a> (per-task buttons), or <a href="/runs/new?from_task={{.Spec.ID}}.">the runs page</a>.</p>
    {{end}}
  {{end}}
</section>

<script src="/static/clipboard.js" defer></script>
{{end}}
