{{define "title"}}rex — specs{{end}}

{{define "content"}}
<header class="page-header">
  <h1>specs</h1>
  <div class="meta">
    <span>{{len .Specs}} spec{{if ne (len .Specs) 1}}s{{end}} in <code>.rex/specs/</code></span>
  </div>
</header>

<section class="section">
  {{if ne .Shell "central"}}
    <div class="toolbar">
      <a class="btn btn-primary" href="/specs/new">new spec</a>
      <form method="post" action="/specs/validate"><button type="submit" class="btn">validate all</button></form>
    </div>
  {{end}}

  {{if .Specs}}
    <div class="card">
      <table class="table sortable">
        <thead>
          <tr>
            <th data-sort-type="string" data-sort-default="asc">id</th>
            <th data-sort-type="string">name</th>
            <th data-sort-type="string">state</th>
            <th data-sort-type="number" class="col-numeric">tasks</th>
            <th data-sort-type="number" class="col-numeric">components</th>
          </tr>
        </thead>
        <tbody>
          {{range .Specs}}
            {{template "spec_row" .}}
          {{end}}
        </tbody>
      </table>
    </div>
  {{else}}
    <div class="empty-state">
      <h3>no specs yet</h3>
      {{if eq .Shell "central"}}
        <p>Specs live in the workspace's <code>.rex/specs/</code> directory and sync via
           <code>rex sync</code>. Create one locally with <code>rex spec create &lt;id&gt;</code>
           then sync to push it here.</p>
      {{else}}
        <p>Create the first one with <code>rex spec create &lt;id&gt;</code> or
           <a href="/specs/new">via the browser form</a>.</p>
      {{end}}
    </div>
  {{end}}
</section>
{{end}}
