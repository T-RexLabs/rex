{{define "title"}}rex — runs{{end}}

{{define "content"}}
<header class="page-header">
  <h1>runs</h1>
  <div class="meta">
    <span>{{len .Runs}} run{{if ne (len .Runs) 1}}s{{end}}</span>
    {{if .SpecFilter}}
      <span>·</span>
      <span>filtered by <code>{{.SpecFilter}}</code></span>
      <span>·</span>
      <a href="/runs">clear</a>
    {{end}}
  </div>
</header>

<section class="section">
  {{if .CanStartRuns}}
    <div class="toolbar">
      <a class="btn btn-primary" href="/runs/new">start a run</a>
    </div>
  {{end}}

  {{if .Runs}}
    <div class="card">
      <table class="table sortable">
        <thead>
          <tr>
            <th data-sort-type="string" data-sort-default="asc">name</th>
            <th data-sort-type="string">kind</th>
            <th data-sort-type="string">status</th>
            <th data-sort-type="string">from task</th>
            <th data-sort-type="date" data-sort-default="desc" aria-sort="descending">started</th>
            <th data-sort-type="date">finished</th>
            <th data-sort-type="number" class="col-numeric">duration</th>
          </tr>
        </thead>
        <tbody>
          {{range .Runs}}
            {{template "run_row" .}}
          {{end}}
        </tbody>
      </table>
    </div>
  {{else}}
    <div class="empty-state">
      <h3>no runs yet</h3>
      {{if .CanStartRuns}}
        <p>Start one with <code>rex run start --shell &lt;cmd&gt;</code> or
           <a href="/runs/new">via the browser form</a>.</p>
      {{else if eq .Shell "central"}}
        <p>Runs are recorded when a local node executes them (<code>rex run start ...</code>),
           then sync to the central via <code>rex sync</code>. Live SSE on central
           lands with v1.5 (web-ui.central-live-run-watching).</p>
      {{else}}
        <p>Start one with <code>rex run start --shell &lt;cmd&gt;</code>.</p>
      {{end}}
    </div>
  {{end}}
</section>
{{end}}
