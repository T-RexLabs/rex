{{define "title"}}rex-central — org {{.OrgID}} members{{end}}

{{define "content"}}
<header class="page-header">
  <h1>members</h1>
  <div class="meta">
    <span>org: <code>{{.OrgID}}</code></span>
    {{if .Members}}
      <span>·</span>
      <span>{{len .Members}} member{{if ne (len .Members) 1}}s{{end}}</span>
    {{end}}
  </div>
</header>

{{if .Flash}}
  <section class="section">
    <aside class="banner banner-success" role="status">
      <span>{{.Flash}}</span>
    </aside>
  </section>
{{end}}

{{if not .ViewerIsAdmin}}
  <section class="section">
    <div class="callout">
      <p><strong>Read-only for this role.</strong>
         Promote / demote / remove / invite require the
         <code>admin</code> role in this org.</p>
    </div>
  </section>
{{end}}

{{if .JustIssuedToken}}
  <section class="section">
    <aside class="banner banner-info" role="status">
      <p><strong>Invite issued.</strong> Share this token with the
         invitee over a secure channel — it's shown once here and
         then only retrievable from the pending-invites table below.</p>
      <pre class="login-cmd"><code>{{.JustIssuedToken}}</code></pre>
    </aside>
  </section>
{{end}}

{{if .ViewerIsAdmin}}
  <section class="section">
    <div class="section-head">
      <h2>invite</h2>
      <span class="section-meta">creates a 7-day token the invitee
        redeems via the (pending) <code>rex remote join</code>
        subcommand</span>
    </div>
    <form method="post" action="/orgs/{{.OrgID}}/members/invite" class="invite-form">
      <label>
        role:
        <select name="role" aria-label="role">
          <option value="member" selected>member</option>
          <option value="admin">admin</option>
          <option value="viewer">viewer</option>
        </select>
      </label>
      <button class="btn btn-primary" type="submit">issue invite</button>
    </form>
  </section>

  {{if .PendingInvites}}
    <section class="section">
      <div class="section-head">
        <h2>pending invites</h2>
        <span class="section-meta">{{len .PendingInvites}} unredeemed</span>
      </div>
      <div class="card">
        <table class="table">
          <thead>
            <tr>
              <th>token</th>
              <th>role</th>
              <th>invited by</th>
              <th>expires</th>
            </tr>
          </thead>
          <tbody>
            {{range .PendingInvites}}
              <tr>
                <td><code class="dim">{{.Token}}</code></td>
                <td><span class="pill pill-{{.Role}}"><i class="dot"></i>{{.Role}}</span></td>
                <td><code class="dim">{{.InvitedBy}}</code></td>
                <td><time>{{.ExpiresAt.UTC.Format "2006-01-02 15:04 UTC"}}</time></td>
              </tr>
            {{end}}
          </tbody>
        </table>
      </div>
    </section>
  {{end}}
{{end}}

<section class="section">
  {{if .Members}}
    <div class="card">
      <table class="table sortable">
        <thead>
          <tr>
            <th data-sort-type="string" data-sort-default="asc">fingerprint</th>
            <th data-sort-type="string">role</th>
            <th data-sort-type="date">joined</th>
            {{if .ViewerIsAdmin}}<th>actions</th>{{end}}
          </tr>
        </thead>
        <tbody>
          {{range .Members}}
            <tr>
              <td><code>{{.Fingerprint}}</code></td>
              <td>
                {{if $.ViewerIsAdmin}}
                  <form method="post" action="/orgs/{{$.OrgID}}/members/{{.Fingerprint}}/role" class="role-form">
                    <select name="role" aria-label="role">
                      <option value="admin"  {{if eq .Role "admin"}}selected{{end}}>admin</option>
                      <option value="member" {{if eq .Role "member"}}selected{{end}}>member</option>
                      <option value="viewer" {{if eq .Role "viewer"}}selected{{end}}>viewer</option>
                    </select>
                    <button class="btn btn-small" type="submit">save</button>
                  </form>
                {{else}}
                  <span class="pill pill-{{.Role}}"><i class="dot"></i>{{.Role}}</span>
                {{end}}
              </td>
              <td>
                {{if not .JoinedAt.IsZero}}
                  <time>{{.JoinedAt.UTC.Format "2006-01-02 15:04 UTC"}}</time>
                {{else}}
                  <span class="dim">—</span>
                {{end}}
              </td>
              {{if $.ViewerIsAdmin}}
                <td>
                  <form method="post" action="/orgs/{{$.OrgID}}/members/{{.Fingerprint}}/remove" class="remove-form"
                        onsubmit="return confirm('Remove {{.Fingerprint}} from this org?');">
                    <button class="btn btn-small btn-danger" type="submit">remove</button>
                  </form>
                </td>
              {{end}}
            </tr>
          {{end}}
        </tbody>
      </table>
    </div>
  {{else}}
    <p class="muted small">no members in this org</p>
  {{end}}
</section>
{{end}}
