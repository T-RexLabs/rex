{{define "title"}}rex — remotes{{end}}

{{define "content"}}
<header class="page-header">
  <h1>remotes</h1>
  <div class="meta">
    {{if .Source}}<span>registered in <code>{{.Source}}</code></span>{{end}}
    {{if .AddCmd}}<span>·</span><span>add via <code>{{.AddCmd}}</code></span>{{end}}
  </div>
</header>

<section class="section">
  {{if .Rows}}
    <div class="card">
      <table class="table sortable">
        <thead>
          <tr>
            <th data-sort-type="string" data-sort-default="asc">name</th>
            <th data-sort-type="string">url</th>
            <th data-sort-type="string">drafts</th>
            <th data-sort-type="string">fingerprint</th>
            <th data-sort-type="date">added</th>
            <th data-sort-type="date">last seen</th>
          </tr>
        </thead>
        <tbody>
          {{range .Rows}}
          <tr>
            <td><code>{{.Name}}</code></td>
            <td><code>{{.URL}}</code></td>
            <td>{{template "draft_indicator" .IndicatorView}}</td>
            <td>{{if .Fingerprint}}<code>{{.Fingerprint}}</code>{{else}}<span class="dim">—</span>{{end}}</td>
            <td>{{if .AddedAt}}<time>{{.AddedAt}}</time>{{else}}<span class="dim">—</span>{{end}}</td>
            <td>{{if .LastSeen}}<time>{{.LastSeen}}</time>{{else}}<span class="dim">—</span>{{end}}</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
  {{else}}
    {{if .AddCmd}}
      <p class="muted small">no remotes registered — <code>{{.AddCmd}}</code></p>
    {{else}}
      <p class="muted small">no remotes registered for this workspace</p>
    {{end}}
  {{end}}
</section>
{{end}}
