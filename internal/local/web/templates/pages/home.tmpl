{{define "title"}}rex — {{.Workspace.ID}}{{end}}

{{define "content"}}
<div class="split">
  <div class="split-main">
    <section class="overview">
      <p class="eyebrow">workspace</p>
      <h1>{{.Workspace.Name}}</h1>
      <dl class="kv">
        <dt>id</dt><dd><code>{{.Workspace.ID}}</code></dd>
        <dt>state</dt><dd><span class="pill pill-{{.Workspace.State}}"><i class="dot"></i>{{.Workspace.State}}</span></dd>
        <dt>created</dt><dd><time>{{.Workspace.CreatedAt}}</time></dd>
        <dt>specs</dt><dd>{{.SpecCount}}</dd>
        <dt>runs</dt><dd>{{.RunCount}}</dd>
        <dt>events total</dt><dd>{{.EventCount}}</dd>
      </dl>
    </section>

    <section class="card">
      <p class="card-eyebrow">recent runs</p>
      {{if .RecentRuns}}
        <table class="table">
          <thead><tr><th>run</th><th>status</th><th>started</th><th>nodes</th></tr></thead>
          <tbody>
            {{range .RecentRuns}}
            <tr>
              <td><a href="/runs/{{.RunID}}"><code>{{.RunID}}</code></a></td>
              <td><span class="pill pill-{{.Status}}"><i class="dot"></i>{{.Status}}</span></td>
              <td><time>{{.StartedAt}}</time></td>
              <td>{{.NodeEvents}}</td>
            </tr>
            {{end}}
          </tbody>
        </table>
      {{else}}
        <p class="muted">no runs yet — start one from the rail, or <code>rex run start --shell &lt;cmd&gt;</code></p>
      {{end}}
    </section>

    <section class="card">
      <p class="card-eyebrow">remotes</p>
      {{if .Remotes}}
        <table class="table">
          <thead><tr><th>name</th><th>drafts</th><th>last sync</th></tr></thead>
          <tbody>
            {{range .Remotes}}
            <tr>
              <td><code>{{.Name}}</code></td>
              <td>{{.Drafts}}</td>
              <td><time>{{.LastSync}}</time></td>
            </tr>
            {{end}}
          </tbody>
        </table>
      {{else}}
        <p class="muted">no remotes registered — <code>rex remote add &lt;name&gt; &lt;url&gt;</code></p>
      {{end}}
    </section>
  </div>

  <aside class="split-rail">
    <p class="eyebrow">commands</p>
    <div class="commands">
      <a class="command" href="/runs/new">
        <span class="command-title">start a run</span>
        <span class="command-hint">one-shot shell command, synchronous</span>
      </a>
      <form method="post" action="/specs/validate" class="command-form">
        <button class="command" type="submit" style="width: 100%; text-align: left; cursor: pointer;">
          <span class="command-title">validate specs</span>
          <span class="command-hint">strict pass over <code>.rex/specs</code></span>
        </button>
      </form>
      <a class="command command-disabled" aria-disabled="true" title="sync now is a CLI-only flow in v1; remote selection + error surface needs more design before it lands here">
        <span class="command-title">sync now <span class="muted">(CLI only · v1)</span></span>
        <span class="command-hint"><code>rex sync</code> from the terminal</span>
      </a>
    </div>
  </aside>
</div>
{{end}}
