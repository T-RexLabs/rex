{{define "title"}}rex — {{.Workspace.ID}}{{end}}

{{define "content"}}
<header class="page-header">
  <h1>{{.Workspace.Name}}</h1>
  <div class="meta meta-spread">
    <code>{{.Workspace.ID}}</code>
    <span class="pill pill-{{.Workspace.State}}"><i class="dot"></i>{{.Workspace.State}}</span>
    <span>{{.SpecCount}} spec{{if ne .SpecCount 1}}s{{end}}</span>
    <span>{{.RunCount}} run{{if ne .RunCount 1}}s{{end}}</span>
    <span>{{.EventCount}} event{{if ne .EventCount 1}}s{{end}}</span>
  </div>
</header>

<section class="section">
  <div class="section-head">
    <h2>quick actions</h2>
    <span class="section-meta">parity with the cli's daily-driver flows</span>
  </div>
  <div class="quick-actions">
    <a class="btn btn-primary" href="/runs/new">start a run</a>
    <a class="btn" href="/specs/new">new spec</a>
    <form method="post" action="/specs/validate"><button type="submit" class="btn">validate specs</button></form>
    <a class="btn" href="/specs">browse specs</a>
    <a class="btn" href="/sync">sync now</a>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <h2>recent runs</h2>
    <a class="section-meta" href="/runs">all runs <span aria-hidden="true">→</span></a>
  </div>
  {{if .RecentRuns}}
    <div class="card">
      <table class="table sortable">
        <thead>
          <tr>
            <th data-sort-type="string">name</th>
            <th data-sort-type="string">kind</th>
            <th data-sort-type="string">status</th>
            <th data-sort-type="date" data-sort-default="desc" aria-sort="descending">started</th>
            <th data-sort-type="number" class="col-numeric">duration</th>
          </tr>
        </thead>
        <tbody>
          {{range .RecentRuns}}
          <tr>
            <td><a href="/runs/{{.RunID}}"><code>{{.Name}}</code></a></td>
            <td><span class="pill pill-{{.Kind}}">{{.Kind}}</span></td>
            <td><span class="pill pill-{{.Status}}"><i class="dot"></i>{{.Status}}</span></td>
            <td><time>{{.StartedAt}}</time></td>
            <td class="col-numeric">{{if .Duration}}{{.Duration}}{{else}}<span class="dim">—</span>{{end}}</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
  {{else}}
    <p class="muted small">no runs yet — <a href="/runs/new">start one</a> or use <code>rex run start --shell &lt;cmd&gt;</code></p>
  {{end}}
</section>

<section class="section">
  <div class="section-head">
    <h2>remotes</h2>
    <a class="section-meta" href="/remotes">all remotes <span aria-hidden="true">→</span></a>
  </div>
  {{if .Remotes}}
    <div class="card">
      <table class="table sortable">
        <thead>
          <tr>
            <th data-sort-type="string" data-sort-default="asc">name</th>
            <th data-sort-type="number" class="col-numeric">drafts</th>
            <th data-sort-type="date">last sync</th>
          </tr>
        </thead>
        <tbody>
          {{range .Remotes}}
          <tr>
            <td><code>{{.Name}}</code></td>
            <td class="col-numeric">{{.Drafts}}</td>
            <td><time>{{.LastSync}}</time></td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
  {{else}}
    <p class="muted small">no remotes registered — <code>rex remote add &lt;name&gt; &lt;url&gt;</code></p>
  {{end}}
</section>
{{end}}
