{{define "title"}}rex — start a run{{end}}

{{define "content"}}
<header class="page-header">
  <h1>start a run</h1>
  <div class="meta">
    <span>one-shot shell command, runs synchronously</span>
    <span class="back"><a href="/runs"><span aria-hidden="true">←</span> all runs</a></span>
  </div>
</header>

{{if .Error}}
<aside class="banner banner-error" role="alert">
  <span><strong>could not start.</strong> {{.Error}}</span>
</aside>
{{end}}

<section class="section">
  <div class="card">
    <form method="post" action="/runs/start" class="form">
      <div class="form-grid">
        <label class="field full">
          <span class="field-label">shell command <span class="req">*</span></span>
          <input class="field-input mono"
                 type="text"
                 name="shell"
                 autocomplete="off"
                 autofocus
                 required
                 placeholder='echo hello && date'
                 value="{{.Shell}}">
          <span class="field-hint">POSIX-ish: bare words and double-quoted runs. Single quotes and backslash escapes are not yet honoured.</span>
        </label>

        <label class="field">
          <span class="field-label">node id</span>
          <input class="field-input mono"
                 type="text"
                 name="node_id"
                 value="{{.NodeID}}"
                 placeholder="shell">
          <span class="field-hint">Defaults to <code>shell</code>. Visible in <code>run.show</code> output.</span>
        </label>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">start run</button>
        <a class="btn btn-ghost" href="/runs">cancel</a>
      </div>
    </form>
  </div>
</section>
{{end}}
