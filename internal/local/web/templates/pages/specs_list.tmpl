{{define "title"}}rex — specs{{end}}

{{define "content"}}
<header class="page-header">
  <h1>specs</h1>
  <div class="meta">
    <span>{{len .Specs}} spec{{if ne (len .Specs) 1}}s{{end}} in <code>.rex/specs/</code></span>
  </div>
</header>

<section class="section">
  <div class="toolbar">
    <a class="btn btn-primary" href="/specs/new">new spec</a>
    <form method="post" action="/specs/validate"><button type="submit" class="btn">validate all</button></form>
  </div>

  {{if .Specs}}
    <div class="card">
      <table class="table sortable">
        <thead>
          <tr>
            <th data-sort-type="string" data-sort-default="asc">id</th>
            <th data-sort-type="string">name</th>
            <th data-sort-type="string">state</th>
            <th data-sort-type="number" class="col-numeric">tasks</th>
            <th data-sort-type="number" class="col-numeric">components</th>
          </tr>
        </thead>
        <tbody>
          {{range .Specs}}
            {{template "spec_row" .}}
          {{end}}
        </tbody>
      </table>
    </div>
  {{else}}
    <p class="muted small">no specs yet — <a href="/specs/new">create the first one</a></p>
  {{end}}
</section>
{{end}}
