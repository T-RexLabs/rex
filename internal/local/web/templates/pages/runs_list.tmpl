{{define "title"}}rex — runs{{end}}

{{define "content"}}
<section class="overview">
  <p class="eyebrow">workspace · runs</p>
  <h1>runs</h1>
  <p class="muted">{{len .Runs}} run{{if ne (len .Runs) 1}}s{{end}}</p>
</section>

<section class="card">
  {{if .Runs}}
    <table class="table">
      <thead><tr><th>run</th><th>status</th><th>started</th><th>nodes</th></tr></thead>
      <tbody>
        {{range .Runs}}
        <tr>
          <td><a href="/runs/{{.RunID}}"><code>{{.RunID}}</code></a></td>
          <td><span class="pill pill-{{.Status}}"><i class="dot"></i>{{.Status}}</span></td>
          <td><time>{{.StartedAt}}</time></td>
          <td>{{.NodeEvents}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  {{else}}
    <p class="muted">no runs yet</p>
  {{end}}
</section>

<a class="btn btn-primary" href="/runs/new">+ start a run</a>
{{end}}
