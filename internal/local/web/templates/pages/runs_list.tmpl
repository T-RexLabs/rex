{{define "title"}}rex — runs{{end}}

{{define "content"}}
<header class="page-header">
  <h1>runs</h1>
  <div class="meta">
    <span>{{len .Runs}} run{{if ne (len .Runs) 1}}s{{end}}</span>
  </div>
</header>

<section class="section">
  <div class="toolbar">
    <a class="btn btn-primary" href="/runs/new">start a run</a>
  </div>

  {{if .Runs}}
    <div class="card">
      <table class="table sortable">
        <thead>
          <tr>
            <th data-sort-type="string" data-sort-default="asc">name</th>
            <th data-sort-type="string">run</th>
            <th data-sort-type="string">kind</th>
            <th data-sort-type="string">status</th>
            <th data-sort-type="date" data-sort-default="desc" aria-sort="descending">started</th>
            <th data-sort-type="number" class="col-numeric">nodes</th>
          </tr>
        </thead>
        <tbody>
          {{range .Runs}}
          <tr>
            <td><a href="/runs/{{.RunID}}"><code>{{.Name}}</code></a></td>
            <td><code class="muted">{{.RunID}}</code></td>
            <td><span class="pill pill-{{.Kind}}">{{.Kind}}</span></td>
            <td><span class="pill pill-{{.Status}}"><i class="dot"></i>{{.Status}}</span></td>
            <td><time>{{.StartedAt}}</time></td>
            <td class="col-numeric">{{.NodeEvents}}</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
  {{else}}
    <p class="muted small">no runs yet — <a href="/runs/new">start one</a></p>
  {{end}}
</section>
{{end}}
