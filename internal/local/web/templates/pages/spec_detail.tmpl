{{define "title"}}rex — {{.Spec.ID}}{{end}}

{{define "content"}}
<header class="page-header">
  <div class="header-row">
    <h1>{{.Spec.Name}}</h1>
    <div class="header-actions">
      <a class="btn" href="/runs?spec={{.Spec.ID}}">view runs</a>
      <a class="btn" href="/specs/{{.Spec.ID}}/edit">edit</a>
    </div>
  </div>
  <div class="meta">
    <code>{{.Spec.ID}}</code>
    <span>·</span>
    <span class="pill pill-{{.Spec.State}}"><i class="dot"></i>{{.Spec.State}}</span>
    {{if .Spec.UpdatedAt}}<span>·</span><span>updated <time>{{.Spec.UpdatedAt}}</time></span>{{end}}
    <span class="back"><a href="/specs"><span aria-hidden="true">←</span> all specs</a></span>
  </div>
</header>

<nav class="tabs" aria-label="spec view">
  <a class="tab"
     {{if eq .ActiveTab "rendered"}}aria-selected="true"{{end}}
     href="?tab=rendered">rendered</a>
  <a class="tab"
     {{if eq .ActiveTab "source"}}aria-selected="true"{{end}}
     href="?tab=source">yaml source</a>
  <a class="tab"
     {{if eq .ActiveTab "tasks"}}aria-selected="true"{{end}}
     href="?tab=tasks">tasks <span class="count">{{len .Spec.Tasks}}</span></a>
</nav>

<section class="section">
  {{if eq .ActiveTab "rendered"}}
    {{if .Spec.DescriptionParas}}
      <div class="prose">
        {{range .Spec.DescriptionParas}}<p>{{.}}</p>{{end}}
      </div>
    {{else}}
      <p class="muted">no description.</p>
    {{end}}

    {{if .Spec.Components}}
      <h2 class="section-h2">components</h2>
      {{range $cid := .Spec.ComponentOrder}}
        {{$c := index $.Spec.Components $cid}}
        <article class="component-block">
          <header class="component-block-head">
            <span class="component-id">{{$cid}}</span>
            <span class="component-name">{{$c.Name}}</span>
            <span class="component-count">{{len $c.Requirements}} requirement{{if ne (len $c.Requirements) 1}}s{{end}}</span>
          </header>
          {{range $rid := $c.RequirementOrder}}
            {{$r := index $c.Requirements $rid}}
            <div class="requirement" id="{{$.Spec.ID}}.{{$cid}}.{{$rid}}">
              <div class="requirement-acid">
                <a class="acid"
                   data-acid="{{$.Spec.ID}}.{{$cid}}.{{$rid}}"
                   href="#{{$.Spec.ID}}.{{$cid}}.{{$rid}}"
                   title="copy acid">{{$.Spec.ID}}.{{$cid}}.{{$rid}}</a>
              </div>
              <div class="requirement-text">{{$r.Text}}</div>
            </div>
          {{end}}
        </article>
      {{end}}
    {{end}}

    {{if .Spec.Constraints}}
      <h2 class="section-h2">constraints</h2>
      {{range $cid := .Spec.ConstraintOrder}}
        {{$c := index $.Spec.Constraints $cid}}
        <article class="component-block">
          <header class="component-block-head">
            <span class="component-id">{{$cid}}</span>
            <span class="component-name">{{$c.Description}}</span>
            <span class="component-count">{{len $c.Requirements}} rule{{if ne (len $c.Requirements) 1}}s{{end}}</span>
          </header>
          {{range $rid := $c.RequirementOrder}}
            {{$r := index $c.Requirements $rid}}
            <div class="requirement" id="{{$.Spec.ID}}.{{$cid}}.{{$rid}}">
              <div class="requirement-acid">
                <a class="acid"
                   data-acid="{{$.Spec.ID}}.{{$cid}}.{{$rid}}"
                   href="#{{$.Spec.ID}}.{{$cid}}.{{$rid}}"
                   title="copy acid">{{$.Spec.ID}}.{{$cid}}.{{$rid}}</a>
              </div>
              <div class="requirement-text">{{$r.Text}}</div>
            </div>
          {{end}}
        </article>
      {{end}}
    {{end}}

  {{else if eq .ActiveTab "source"}}
    {{if .YAMLPretty}}
      <pre class="source chroma"><code class="language-yaml">{{.YAMLPretty}}</code></pre>
    {{else}}
      <pre class="source"><code>{{.RawYAML}}</code></pre>
    {{end}}

  {{else if eq .ActiveTab "tasks"}}
    {{if .Spec.Tasks}}
      <div class="card">
        {{range .Spec.Tasks}}
          {{$runs := index $.RunsByTask .ID}}
          <div class="task">
            <div class="task-id"><code>{{.ID}}</code></div>
            <div><span class="pill pill-{{.State}}"><i class="dot"></i>{{.State}}</span></div>
            <div class="task-body">
              <div>{{.Description}}</div>
              {{if .References}}
                <div class="task-refs">
                  {{range .References}}
                    <a class="acid acid-sm" data-acid="{{.}}" href="#" title="copy acid">{{.}}</a>
                  {{end}}
                </div>
              {{end}}
              {{if .HasRecipe}}
                <form class="task-run" method="post" action="/specs/{{$.Spec.ID}}/tasks/{{.ID}}/run">
                  <button type="submit" class="btn btn-primary">run this task</button>
                  <span class="muted">via <code>{{.RecipeKind}}</code> recipe</span>
                </form>
              {{end}}
              {{if $runs}}
                {{$latest := index $runs 0}}
                <details class="task-runs">
                  <summary>
                    <span class="pill pill-{{$latest.Status}}" title="latest run: {{$latest.Status}}"><i class="dot"></i>{{len $runs}} run{{if ne (len $runs) 1}}s{{end}}</span>
                    <span class="muted">latest <a href="/runs/{{$latest.RunID}}"><code>{{$latest.Name}}</code></a></span>
                  </summary>
                  <ul class="task-runs-list">
                    {{range $runs}}
                      <li>
                        <span class="pill pill-{{.Status}} pill-sm"><i class="dot"></i>{{.Status}}</span>
                        <a href="/runs/{{.RunID}}"><code>{{.Name}}</code></a>
                        <time class="muted small">{{.StartedAt}}</time>
                      </li>
                    {{end}}
                  </ul>
                </details>
              {{end}}
            </div>
          </div>
        {{end}}
      </div>
      {{if .UntaskedRuns}}
        <div class="card untasked-runs">
          <h3 class="section-h3">runs citing this spec without a task</h3>
          <ul class="task-runs-list">
            {{range .UntaskedRuns}}
              <li>
                <span class="pill pill-{{.Status}} pill-sm"><i class="dot"></i>{{.Status}}</span>
                <a href="/runs/{{.RunID}}"><code>{{.Name}}</code></a>
                <time class="muted small">{{.StartedAt}}</time>
              </li>
            {{end}}
          </ul>
        </div>
      {{end}}
    {{else}}
      <p class="muted">no tasks defined.</p>
    {{end}}
  {{end}}
</section>

<script src="/static/clipboard.js" defer></script>
{{end}}
