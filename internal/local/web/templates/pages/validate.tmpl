{{define "title"}}rex — validate{{end}}

{{define "content"}}
<header class="page-header">
  <h1>validation report</h1>
  <div class="meta">
    <span>strict pass · mirrors <code>rex spec validate specs/*.yaml</code></span>
    <span class="back"><a href="/specs">← all specs</a></span>
  </div>
</header>

<section class="section">
  <div class="card">
    <dl class="kv">
      <dt>specs scanned</dt><dd class="num">{{.SpecCount}}</dd>
      <dt>errors</dt>
      <dd>{{if .Errors}}<span class="pill pill-error"><i class="dot"></i>{{.Errors}}</span>{{else}}<span class="pill pill-ok"><i class="dot"></i>0</span>{{end}}</dd>
      <dt>warnings</dt>
      <dd>{{if .Warnings}}<span class="pill pill-warn"><i class="dot"></i>{{.Warnings}}</span>{{else}}<span class="pill pill-ok"><i class="dot"></i>0</span>{{end}}</dd>
    </dl>
  </div>

  <div class="section-head"><h2>issues</h2></div>
  {{if .Issues}}
    <div class="card">
      <table class="table">
        <thead>
          <tr><th>severity</th><th>file</th><th>path</th><th>category</th><th>message</th></tr>
        </thead>
        <tbody>
          {{range .Issues}}
          <tr>
            <td><span class="pill pill-{{if eq .Severity "error"}}error{{else}}warn{{end}}"><i class="dot"></i>{{.Severity}}</span></td>
            <td><code>{{.File}}</code></td>
            <td><code class="dim">{{if .Path}}{{.Path}}{{else}}—{{end}}</code></td>
            <td><code>{{.Category}}</code></td>
            <td>{{.Message}}</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
  {{else}}
    <p class="muted small">no issues — the workspace's specs are clean.</p>
  {{end}}
</section>
{{end}}
