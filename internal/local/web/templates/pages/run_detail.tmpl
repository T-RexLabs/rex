{{define "title"}}rex — run {{.Name}}{{end}}

{{define "runEventsList"}}
  {{range .Events}}
    {{if and .Compact (not $.Debug)}}
      {{if .Frame}}
        <div class="event-compact event-compact-meta" data-event-id="{{.ID}}">
          <time class="event-time">{{.Timestamp}}</time>
          <span class="compact-bullet">·</span>
          <span class="compact-label">{{.Frame.Method}}{{if .Frame.Text}} · {{.Frame.Text}}{{end}}</span>
        </div>
      {{else}}
        <div class="event-compact event-compact-lifecycle" data-event-id="{{.ID}}" data-run-id="{{$.RunID}}">
          <time class="event-time">{{.Timestamp}}</time>
          <span class="compact-bullet">●</span>
          <span class="compact-label"><code>{{.Type}}</code> · {{.Summary}}</span>
        </div>
      {{end}}
    {{else if .Frame}}
      <article class="event frame frame-{{.Frame.Kind}}" data-event-id="{{.ID}}" data-frame-kind="{{.Frame.Kind}}" data-frame-role="{{.Frame.Role}}"{{if .Frame.ToolCallID}} data-tool-call-id="{{.Frame.ToolCallID}}"{{end}}>
        <header class="event-head">
          <span class="frame-role frame-role-{{.Frame.Role}}">{{if eq .Frame.Role "user"}}you{{else}}{{.Frame.Role}}{{end}}</span>
          <span class="frame-kind muted small">{{if eq .Frame.Kind "agent_text"}}message{{else if eq .Frame.Kind "agent_thought"}}thought{{else}}{{.Frame.Kind}}{{end}}{{if .Frame.Method}} · <code>{{.Frame.Method}}</code>{{end}}</span>
          <time class="event-time">{{.Timestamp}}</time>
        </header>
        {{if eq .Frame.Kind "agent_text"}}
          <div class="frame-body frame-text" data-frame-text>{{.Frame.Text}}</div>
        {{else if eq .Frame.Kind "agent_thought"}}
          <div class="frame-body frame-text frame-thought" data-frame-text>{{.Frame.Text}}</div>
        {{else if or (eq .Frame.Kind "tool_call") (eq .Frame.Kind "tool_result")}}
          <div class="frame-body frame-tool" data-tool-body>
            <span class="tool-arrow">{{if eq .Frame.Kind "tool_call"}}→{{else}}←{{end}}</span>
            <code class="tool-name" data-tool-name>{{.Frame.ToolName}}</code>
            <span class="tool-subtitle muted small" data-tool-subtitle{{if not .Frame.Subtitle}} hidden{{end}}>{{.Frame.Subtitle}}</span>
            <span class="pill pill-{{if eq .Frame.Status ""}}pending{{else if or (eq .Frame.Status "ok") (eq .Frame.Status "running") (eq .Frame.Status "pending") (eq .Frame.Status "error")}}{{.Frame.Status}}{{else}}ok{{end}}" data-tool-status>{{if .Frame.Status}}{{.Frame.Status}}{{else}}pending{{end}}</span>
            {{if .Frame.ToolArgs}}
              <details class="tool-args" data-tool-args>
                <summary class="muted small">{{if eq .Frame.Kind "tool_call"}}args{{else}}result{{end}}</summary>
                <pre class="chroma"><code class="language-json">{{.Frame.ToolArgs}}</code></pre>
              </details>
            {{end}}
            <div class="tool-output" data-tool-output{{if not .Frame.ToolOutput}} hidden{{end}}>{{.Frame.ToolOutput}}</div>
          </div>
        {{else if eq .Frame.Kind "plan"}}
          <div class="frame-body frame-text">{{.Frame.Text}}</div>
        {{else}}
          <div class="frame-body muted small">{{.Frame.Text}}</div>
        {{end}}
        <div class="frame-debug">
          <details>
            <summary class="muted small">raw frame · <code>{{.ID}}</code></summary>
            <pre class="event-body chroma"><code class="language-json">{{.Payload}}</code></pre>
          </details>
        </div>
      </article>
    {{else}}
      <article class="event{{if .Permission}} event-permission{{end}}"{{if .Permission}} id="{{.Permission.RequestID}}"{{end}}>
        <header class="event-head">
          <span class="event-type" data-type="{{.Type}}"><code>{{.Type}}</code></span>
          <time class="event-time">{{.Timestamp}}</time>
          <span class="event-id"><code>{{.ID}}</code></span>
        </header>
        <pre class="event-body chroma"><code class="language-json">{{.Payload}}</code></pre>
        {{with .Permission}}
          {{if .Resolved}}
            <div class="permission-resolution permission-{{.Decision}}">
              <span class="permission-label">
                <span class="pill pill-{{if eq .Decision "granted"}}ok{{else}}error{{end}}"><i class="dot"></i>{{.Decision}}</span>
                <span class="muted small">request <code>{{.RequestID}}</code></span>
              </span>
              <span class="permission-meta muted small">
                {{if .Resolver}}by <code>{{.Resolver}}</code> · {{end}}<time>{{.ResolvedAt}}</time>
                {{if .Note}} · {{.Note}}{{end}}
              </span>
            </div>
          {{else}}
            <form class="permission-form" method="post" action="/runs/{{$.RunID}}/permission">
              <input type="hidden" name="request_id" value="{{.RequestID}}">
              <div class="permission-row">
                <span class="permission-label">
                  <span class="pill pill-warn"><i class="dot"></i>awaiting decision</span>
                  <span class="muted small">{{if .Tool}}<code>{{.Tool}}</code> · {{end}}request <code>{{.RequestID}}</code></span>
                </span>
              </div>
              {{if .Reason}}
                <p class="muted small">{{.Reason}}</p>
              {{end}}
              <div class="permission-row">
                <input class="field-input"
                       type="text"
                       name="note"
                       placeholder="optional note for the audit log">
                <button class="btn btn-primary" type="submit" name="decision" value="grant">approve</button>
                <button class="btn" type="submit" name="decision" value="deny">deny</button>
              </div>
            </form>
          {{end}}
        {{end}}
      </article>
    {{end}}
  {{end}}
{{end}}

{{define "content"}}
<header class="page-header">
  <p class="runid-heading">{{.Name}}</p>
  <div class="meta">
    <span class="pill pill-{{.Status}}"><i class="dot"></i>{{.Status}}</span>
    <span>·</span>
    <code class="muted">{{.RunID}}</code>
    <span>·</span>
    <span>{{len .Events}} event{{if ne (len .Events) 1}}s{{end}}</span>
    <span class="back"><a href="/runs"><span aria-hidden="true">←</span> all runs</a></span>
  </div>
  <div class="meta debug-toggle">
    {{if .Debug}}
      <span class="pill pill-warn"><i class="dot"></i>debug</span>
      <a href="/runs/{{.RunID}}" class="muted small">disable raw frames</a>
    {{else}}
      <a href="/runs/{{.RunID}}?debug=1" class="muted small">show raw frames (debug)</a>
    {{end}}
  </div>
</header>

<section class="section{{if .Debug}} run-debug{{end}}"
         hx-ext="sse"
         sse-connect="/runs/{{.RunID}}/stream{{if .LastEventID}}?after={{.LastEventID}}{{end}}{{if .Debug}}{{if .LastEventID}}&{{else}}?{{end}}debug=1{{end}}"
         sse-swap="run-event"
         hx-target="#run-events"
         hx-swap="beforeend"
         data-debug="{{if .Debug}}1{{else}}0{{end}}">
  <div class="section-head">
    <h2>events</h2>
    <span class="section-meta">live · streaming from <code>/runs/{{.RunID}}/stream</code></span>
    <span class="section-meta" id="run-activity-status">status · {{.Status}}</span>
  </div>

  {{if .Debug}}
    <div class="timeline" id="run-events">
      {{template "runEventsList" .}}
    </div>
  {{else}}
    <div class="run-chat-layout">
      <div class="timeline run-transcript" id="run-transcript">
        {{if .OptimisticPrompt}}
          <article class="event frame frame-agent_text" data-event-id="synthetic-prompt" data-frame-kind="agent_text" data-frame-role="user" data-synthetic="prompt">
            <header class="event-head">
              <span class="frame-role frame-role-user">you</span>
              <span class="frame-kind muted small">message</span>
            </header>
            <div class="frame-body frame-text" data-frame-text>{{.OptimisticPrompt}}</div>
          </article>
        {{end}}
      </div>

      <details class="run-activity-panel"{{if eq (printf "%s" .Status) "running"}} open{{end}} data-run-status="{{.Status}}">
        <summary>activity and lifecycle</summary>
        <div class="timeline run-activity-list" id="run-activity"></div>
      </details>

      <div class="timeline run-events-source" id="run-events">
        {{template "runEventsList" .}}
      </div>

      {{if .ActivePrompt}}
        <form class="permission-form run-input-dock" method="post" action="/runs/{{$.RunID}}/permission">
          <input type="hidden" name="request_id" value="{{.ActivePrompt.RequestID}}">
          <div class="permission-row">
            <span class="permission-label">
              <span class="pill pill-warn"><i class="dot"></i>awaiting decision</span>
              <span class="muted small">{{if .ActivePrompt.Tool}}<code>{{.ActivePrompt.Tool}}</code> · {{end}}request <code>{{.ActivePrompt.RequestID}}</code></span>
            </span>
          </div>
          {{if .ActivePrompt.Reason}}
            <p class="muted small">{{.ActivePrompt.Reason}}</p>
          {{end}}
          <div class="permission-row">
            <input class="field-input"
                   type="text"
                   name="note"
                   placeholder="optional note for the audit log">
            <button class="btn btn-primary" type="submit" name="decision" value="grant">approve</button>
            <button class="btn" type="submit" name="decision" value="deny">deny</button>
          </div>
        </form>
      {{else if .AcceptsInput}}
        <form class="permission-form run-input-dock" method="post" action="/runs/{{.RunID}}/input">
          <div class="permission-row">
            <span class="permission-label">
              <span class="pill pill-warn"><i class="dot"></i>interactive session</span>
              <span class="muted small">send a reply to continue this run</span>
            </span>
          </div>
          <div class="permission-row">
            <textarea class="field-input mono" name="text" rows="2" placeholder="your reply" autofocus></textarea>
            <button class="btn btn-primary" type="submit" name="action" value="send">send</button>
            <button class="btn" type="submit" name="action" value="end">end interaction</button>
          </div>
        </form>
      {{end}}
    </div>

    <noscript>
      <p class="muted small">javascript is off: full event timeline and inline controls remain in the events list.</p>
    </noscript>
  {{end}}

  <p class="muted small">disable js for a static, page-reload-only view (web-ui.access.3).</p>
</section>

<script src="/static/htmx.min.js" defer></script>
<script src="/static/htmx-ext-sse.js" defer></script>
<script src="/static/run-stream.js" defer></script>
{{end}}
