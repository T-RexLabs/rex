{{define "title"}}rex — run {{.RunID}}{{end}}

{{define "content"}}
<header class="page-header">
  <p class="runid-heading">{{.RunID}}</p>
  <div class="meta">
    <span class="pill pill-{{.Status}}"><i class="dot"></i>{{.Status}}</span>
    <span>·</span>
    <span>{{len .Events}} event{{if ne (len .Events) 1}}s{{end}}</span>
    <span class="back"><a href="/runs"><span aria-hidden="true">←</span> all runs</a></span>
  </div>
</header>

<section class="section"
         hx-ext="sse"
         sse-connect="/runs/{{.RunID}}/stream{{if .LastEventID}}?after={{.LastEventID}}{{end}}"
         sse-swap="run-event"
         hx-target="#run-events"
         hx-swap="beforeend">
  <div class="section-head">
    <h2>events</h2>
    <span class="section-meta">live · streaming from <code>/runs/{{.RunID}}/stream</code></span>
  </div>
  <div class="timeline" id="run-events">
    {{range .Events}}
    <article class="event">
      <header class="event-head">
        <span class="event-type" data-type="{{.Type}}"><code>{{.Type}}</code></span>
        <time class="event-time">{{.Timestamp}}</time>
        <span class="event-id"><code>{{.ID}}</code></span>
      </header>
      <pre class="event-body chroma"><code class="language-json">{{.Payload}}</code></pre>
    </article>
    {{end}}
  </div>
  <p class="muted small">disable js for a static, page-reload-only view (web-ui.access.3).</p>
</section>

<script src="/static/htmx.min.js" defer></script>
<script src="/static/htmx-ext-sse.js" defer></script>
{{end}}
